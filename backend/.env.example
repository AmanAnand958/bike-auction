# Backend environment variables
# Copy this to .env and fill in your values

# --- Database ---
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/bike_auction

# --- Auth ---
# Generate a random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_a_random_secret

# --- Server ---
PORT=5000
FRONTEND_URL=http://localhost:5173

# --- Bidding ---
# Minimum rupee amount a bid must exceed the current bid by (default: 500)
MIN_BID_INCREMENT=500

# --- Image Uploads (optional) ---
# If not set, admin must paste image URLs manually
# Sign up at https://cloudinary.com (free tier is plenty)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Email Notifications (optional) ---
# If not set, outbid/win emails are skipped silently
# Works with Gmail, Outlook, or any SMTP
#
# Gmail example:
#   EMAIL_HOST=smtp.gmail.com
#   EMAIL_PORT=587
#   EMAIL_SECURE=false
#   EMAIL_USER=you@gmail.com
#   EMAIL_PASS=your_app_password   <- use an App Password, not your real password
#   EMAIL_FROM="Bike Auction" <you@gmail.com>
#
# To get a Gmail App Password: Google Account → Security → 2-Step Verification → App passwords
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# --- Test Database (optional) ---
# If set, npm test will use this DB instead of DATABASE_URL
# Keeps test data separate from dev data
TEST_DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/bike_auction_test
